#!/bin/sh
# pager.app launcher — thin shim that exec's the real pager binary.
#
# Why this file exists:
#   macOS Login Items shows a friendly "pager" name + icon next to the
#   toggle only when the LaunchAgent's executable lives inside a real
#   .app bundle with an Info.plist and AppIcon.icns. Without this shim,
#   the row would show "Item from unidentified developer" + a generic
#   exec icon (which is what 0.4.x looked like).
#
# This file lives at:    $PAGER_ROOT/macos/pager.app/Contents/MacOS/pager
# And exec's:            $PAGER_ROOT/bin/pager  with the original args.
#
# PAGER_ROOT is set in the LaunchAgent's EnvironmentVariables (see
# com.pager.agent.plist.template), substituted at install time. If
# missing (e.g. someone runs this directly without env), fall back to
# computing it from our own location: launcher is at .app/Contents/MacOS/,
# so $here/../../../.. lands at $PAGER_ROOT.
set -eu

if [ -n "${PAGER_ROOT:-}" ]; then
    real="$PAGER_ROOT/bin/pager"
else
    here=$(cd "$(dirname "$0")" && pwd)
    real="$here/../../../../bin/pager"
fi

exec "$real" "$@"
