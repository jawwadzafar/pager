<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pager.watch</string>

    <key>ProgramArguments</key>
    <array>
        <string>__USER_HOME__/pager/bin/pager</string>
        <string>watchdog</string>
        <string>claude</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>70</integer>

    <key>StandardOutPath</key>
    <string>__USER_HOME__/pager/logs/launchd-watch.out</string>
    <key>StandardErrorPath</key>
    <string>__USER_HOME__/pager/logs/launchd-watch.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__BREW_BIN__:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:__USER_HOME__/.local/bin</string>
        <key>HOME</key>
        <string>__USER_HOME__</string>
    </dict>
</dict>
</plist>
