#!/usr/bin/env bash
# pager — persistent remote-session toolkit for Claude Code
# Single binary with subcommands. Run `pager` or `pager help` for the list.
set -euo pipefail

# Resolve our own location even when invoked through a symlink (e.g. when
# `make install` symlinks bin/pager into ~/.local/bin or /usr/local/bin).
__PAGER_BIN_REAL="$(readlink -f "$0" 2>/dev/null || {
  __t="$0"; while [ -L "$__t" ]; do
    __t="$(cd "$(dirname "$__t")" && pwd)/$(readlink "$__t")"
  done; echo "$__t"; })"
__PAGER_ROOT="${PAGER_ROOT:-$(cd "$(dirname "$__PAGER_BIN_REAL")/.." && pwd)}"
[ -f "$__PAGER_ROOT/.env" ] && set -a && . "$__PAGER_ROOT/.env" && set +a

# ─── ansi helpers ────────────────────────────────────────────────────────────
bold()   { printf '\033[1m%s\033[0m' "$*"; }
dim()    { printf '\033[2m%s\033[0m' "$*"; }
red()    { printf '\033[31m%s\033[0m' "$*"; }
green()  { printf '\033[32m%s\033[0m' "$*"; }
yellow() { printf '\033[33m%s\033[0m' "$*"; }

err()     { echo "$(red ERROR): $*" >&2; exit 1; }
require() { command -v "$1" >/dev/null || err "$1 not installed"; }

# ─── platform helpers ──────────────────────────────────────────────────────
# PAGER_OS is "mac" or "linux". Used to branch service-management calls
# (systemctl vs launchctl) and to pick portable coreutils flags.
PAGER_OS="linux"
[ "$(uname -s)" = "Darwin" ] && PAGER_OS="mac"

# file_mode FILE — print octal permission bits (e.g. "600"). Empty on error.
# stat -c is GNU; stat -f is BSD; python is the simple portable answer.
file_mode() {
  python3 -c "import os,sys; print(oct(os.stat(sys.argv[1]).st_mode)[-3:])" "$1" 2>/dev/null
}

# date_to_epoch ISO8601 — print unix epoch seconds for an ISO 8601 timestamp.
# `date -d` is GNU; BSD date needs -j -f with an explicit format. Python's
# fromisoformat handles both colon and no-colon timezone offsets uniformly.
date_to_epoch() {
  python3 -c "from datetime import datetime; import sys; print(int(datetime.fromisoformat(sys.argv[1]).timestamp()))" "$1" 2>/dev/null || echo 0
}

# age_seconds_for_pid PID — print integer seconds a process has been alive.
# `ps -o etimes=` is procps (Linux) only; macOS BSD ps doesn't have it and
# prints its keyword-help text instead, which polluted age_sec in watch.csv
# (the v0.6.3 fix). `ps -o etime=` is portable but prints "[[DD-]HH:]MM:SS";
# we parse it via Python here. Empty output on failure.
age_seconds_for_pid() {
  python3 -c '
import sys, subprocess
try:
    out = subprocess.check_output(["ps", "-o", "etime=", "-p", sys.argv[1]]).decode().strip()
    days = 0
    if "-" in out:
        d, out = out.split("-", 1)
        days = int(d)
    parts = [int(p) for p in out.split(":")]
    if len(parts) == 2:
        secs = parts[0]*60 + parts[1]
    elif len(parts) == 3:
        secs = parts[0]*3600 + parts[1]*60 + parts[2]
    else:
        secs = 0
    print(days * 86400 + secs)
except Exception:
    pass
' "$1" 2>/dev/null
}

# Stop-semaphore — touched by `pager stop`, removed by `pager start`.
# The watchdog checks for this file BEFORE doing any tmux call and noops if
# present. Without this, `pager stop` is non-persistent because the watchdog
# fires 70s later, sees the session is gone, and respawns it. On macOS each
# tmux call from the watchdog also triggers a TCC "access data from other
# apps" prompt — the semaphore avoids both problems.
_pager_stop_file() { printf '%s' "$__PAGER_ROOT/logs/.stopped"; }

# ─── start: launch a session ────────────────────────────────────────────────
cmd_start() {
  require tmux
  # Hard check: claude must exist. Without it, the spawned tmux pane runs
  # `claude --remote-control ...` which immediately fails, the wrapper bash
  # kicks in, and you get a useless session that looks alive but isn't.
  # Better to fail fast with the same install hint bootstrap uses.
  if ! command -v claude >/dev/null 2>&1; then
    err "claude (Claude Code CLI) not found on PATH.\n      Install: https://claude.com/code   (or: npm install -g @anthropic-ai/claude-code)\n      Then re-run: pager start"
  fi
  local session="${1:-claude}"
  shift || true
  [ "${1-}" = "--" ] && shift || true

  if tmux has-session -t "$session" 2>/dev/null; then
    echo "Session '$session' already running. Attach: pager attach $session"
    # Clear the stop semaphore even if the session was already running — the
    # user explicitly asked to start, so the watchdog should resume.
    rm -f "$(_pager_stop_file)" 2>/dev/null || true
    return 0
  fi

  local log="$__PAGER_ROOT/logs/$session.log"
  mkdir -p "$(dirname "$log")"
  # Clear the stop semaphore so the watchdog resumes health checks.
  rm -f "$(_pager_stop_file)" 2>/dev/null || true

  # claude is launched with --dangerously-skip-permissions by default. There's
  # no human at the keyboard when the LaunchAgent fires at login, so without
  # this flag claude would hang on the first permission prompt. The tradeoff
  # is that claude prints a loud red warning banner about Bypass Permissions
  # mode at startup — it's expected, see macos/README.md.
  # PAGER_NO_DANGEROUS=1 opts out for users who'd rather have prompts +
  # potential hangs over the warning banner.
  local claude_cmd="claude"
  if [ -z "${PAGER_NO_DANGEROUS:-}" ]; then
    claude_cmd+=" --dangerously-skip-permissions"
  fi
  if [ -z "${PAGER_NO_REMOTE:-}" ]; then
    claude_cmd+=" --remote-control $(printf '%q' "$session")"
  fi
  for arg in "$@"; do
    claude_cmd+=" $(printf '%q' "$arg")"
  done

  tmux new-session -d -s "$session" -c "$HOME" \
    "$claude_cmd; echo; echo '[claude exited — tmux session kept; run claude to relaunch]'; exec bash"
  tmux pipe-pane -t "$session":0.0 -o "cat >> '$log'"

  echo "Started session '$session'."
  echo "  Attach: pager attach $session"
  echo "  Log:    $log"
  echo "  URL:    pager url $session"
}

# ─── attach: attach terminal to a session ──────────────────────────────────
cmd_attach() {
  require tmux
  local session="${1:-claude}"
  exec tmux attach -t "$session"
}

# ─── stop: kill a session and pause the watchdog ───────────────────────────
# `pager stop` creates a `.stopped` semaphore in logs/ that the watchdog
# checks on every tick. While the semaphore exists, the watchdog logs a
# `manually-stopped` row to watch.csv and exits without touching tmux —
# so the session stays dead and (on macOS) the TCC prompt doesn't fire.
# `pager start` removes the semaphore.
cmd_stop() {
  require tmux
  local nuke_watchdog=0 session
  if [ "${1-}" = "--all" ]; then
    # Touch the semaphore FIRST so any in-flight watchdog tick noops.
    mkdir -p "$__PAGER_ROOT/logs"
    touch "$(_pager_stop_file)"
    tmux ls 2>/dev/null | awk -F: '{print $1}' | while read -r s; do
      tmux kill-session -t "$s" && echo "Killed: $s"
    done
    nuke_watchdog=1
    session="(all)"
  else
    session="${1:-claude}"
    mkdir -p "$__PAGER_ROOT/logs"
    touch "$(_pager_stop_file)"
    if tmux has-session -t "$session" 2>/dev/null; then
      tmux kill-session -t "$session"
      echo "Killed session '$session'."
    else
      echo "No session '$session' running."
    fi
  fi
  echo "Watchdog paused (logs/.stopped) — 'pager start' to resume."
  # With --all, also unload the watchdog process itself so no ticks happen
  # at all (helpful when you want to silence things completely on macOS).
  if [ "$nuke_watchdog" = 1 ]; then
    _watchdog_disable && echo "Watchdog process stopped (use 'pager start' or re-run bootstrap to re-enable)."
  fi
}

# OS-aware watchdog process control. Used by `pager stop --all` to fully
# silence the watchdog (not just pause it via the semaphore). Returns 0 if
# the platform-specific call succeeded, 1 if no watchdog unit was loaded.
_watchdog_disable() {
  if [ "$PAGER_OS" = "mac" ]; then
    launchctl bootout "gui/$(id -u)/com.pager.agent" 2>/dev/null
  else
    systemctl --user stop pager-watch.timer 2>/dev/null
  fi
}

# Re-enable the watchdog process. Mirrors _watchdog_disable.
_watchdog_enable() {
  if [ "$PAGER_OS" = "mac" ]; then
    [ -f "$HOME/Library/LaunchAgents/com.pager.agent.plist" ] || return 1
    launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/com.pager.agent.plist" 2>/dev/null
  else
    systemctl --user start pager-watch.timer 2>/dev/null
  fi
}

# ─── trust: pre-accept Claude Code's "Trust this folder?" dialog for a path ─
# Same flag the bootstrap pre-sets for $HOME. Exposed as a subcommand so users
# can:
#   - Pre-trust additional paths beyond $HOME (e.g. project dirs they want
#     `claude` to operate in without prompting)
#   - Verify trust state after install (--check)
#   - Reset trust for testing (--reset)
#
# Writes to ~/.claude.json's projects.<absolute-path> entry. Idempotent.
cmd_trust() {
  local target_path="$HOME"
  local mode="set"
  while [ $# -gt 0 ]; do
    case "$1" in
      --check) mode="check" ;;
      --reset) mode="reset" ;;
      -h|--help)
        cat <<EOF
$(bold "pager trust") $(dim "[--check | --reset] [PATH]")

  Pre-accept Claude Code's "Trust this folder?" dialog for a directory by
  writing hasTrustDialogAccepted + hasCompletedProjectOnboarding under
  projects.<PATH> in ~/.claude.json. Without it, autostart sessions hang
  on the dialog forever (no human at keyboard).

  PATH defaults to \$HOME. Bootstrap already trusts \$HOME — this command is
  for adding other paths, verifying, or resetting for testing.

  --check    show current trust state for PATH, no changes (exit 0 if trusted)
  --reset    remove the trust entry for PATH

Examples:
  pager trust                           # ensure \$HOME is trusted (default)
  pager trust ~/code/secrets-project    # also trust this specific dir
  pager trust --check ~/code/myproj     # report state, no write
  pager trust --reset ~/code/myproj     # for testing — remove the entry
EOF
        return 0
        ;;
      -*) echo "$(red "Unknown option:") $1  (try: pager trust --help)" >&2; return 1 ;;
      *) target_path="$1" ;;
    esac
    shift
  done

  # Normalize to absolute path. If the dir exists we can `cd` into it; if
  # not (rare — user pre-trusting a path they'll create later), we still
  # write the entry, just without canonicalization.
  if [ -d "$target_path" ]; then
    target_path="$(cd "$target_path" && pwd)"
  fi

  python3 - "$target_path" "$mode" <<'PYEOF'
import json, os, sys
target = sys.argv[1]
mode = sys.argv[2]
p = os.path.expanduser('~/.claude.json')
d = {}
if os.path.exists(p):
    try:
        with open(p) as f: d = json.load(f)
    except json.JSONDecodeError:
        print(f"ERROR: ~/.claude.json is not valid JSON. Move it aside and re-run.", file=sys.stderr)
        sys.exit(2)

projects = d.setdefault('projects', {})
existing = projects.get(target, {})
trusted = bool(existing.get('hasTrustDialogAccepted'))
onboarded = bool(existing.get('hasCompletedProjectOnboarding'))

if mode == 'check':
    if trusted and onboarded:
        print(f'TRUSTED:     {target}')
        sys.exit(0)
    elif trusted:
        print(f'PARTIAL:     {target}  (trust set, onboarding not)')
        sys.exit(1)
    else:
        print(f'NOT TRUSTED: {target}')
        sys.exit(1)

if mode == 'reset':
    if target in projects:
        del projects[target]
        with open(p, 'w') as f: json.dump(d, f, indent=2)
        os.chmod(p, 0o600)
        print(f'RESET:       {target}  (entry removed)')
    else:
        print(f'NOOP:        {target}  (no entry to remove)')
    sys.exit(0)

# mode == 'set'
proj = dict(existing)
proj['hasTrustDialogAccepted'] = True
proj['hasCompletedProjectOnboarding'] = True
projects[target] = proj
with open(p, 'w') as f: json.dump(d, f, indent=2)
os.chmod(p, 0o600)
if trusted and onboarded:
    print(f'ALREADY:     {target}')
else:
    print(f'TRUSTED:     {target}')
PYEOF
}

# ─── autostart: install/remove the LaunchAgent (Mac) or systemd unit (Linux) ──
# As of v0.6.0, the default bootstrap no longer installs the autostart
# unit. Users opt in here, accepting the macOS first-login TCC prompt
# storm (or the linger / login-time start on Linux) in exchange for
# pager surviving reboots. Backed by lib/autostart.sh — same code path
# both bootstraps use when run with --autostart.
cmd_autostart() {
  # shellcheck source=../lib/autostart.sh
  # shellcheck disable=SC1091
  . "$__PAGER_ROOT/lib/autostart.sh"
  case "${1:-status}" in
    enable)        autostart_enable ;;
    disable|off)   autostart_disable ;;
    status|"")     autostart_status ;;
    -h|--help)
      cat <<EOF
$(bold "pager autostart") $(dim "[enable | disable | status]")

  $(bold "enable")     install the autostart unit so pager comes back at login.
              macOS:  LaunchAgent at ~/Library/LaunchAgents/com.pager.agent.plist
              Linux:  systemd --user pager.service + pager-watch.timer
              First-time enable on macOS triggers a stack of TCC prompts —
              see macos/README.md for the safe-to-deny list.
  $(bold "disable")    remove the autostart unit. pager.service / LaunchAgent gone.
              Sessions you started manually with 'pager start' keep running.
  $(bold "status")     print whether autostart is enabled (default if no arg).

Default install does NOT enable autostart. You opt in with 'enable' once,
which is the only time the TCC prompt storm on macOS happens. After that,
choices are remembered.
EOF
      ;;
    *) echo "$(red "Unknown subcommand:") $1  (use --help for usage)" >&2; return 1 ;;
  esac
}

# ─── uninstall: tear down system integration ──────────────────────────────
# Reverses everything macos/bootstrap.sh or Linux bootstrap.sh installed,
# WITHOUT touching the repo directory or your .env (so secrets are safe).
# Mirror image of bootstrap:
#   - Stops + removes the LaunchAgent (Mac) or systemd units (Linux)
#   - Removes ~/.local/bin/pager symlink
#   - Strips the pager .env auto-source line from ~/.bashrc / ~/.zshrc
#   - Leaves $__PAGER_ROOT in place — delete it manually if you want a
#     full nuke. The .env in particular is precious.
cmd_uninstall() {
  local yes=0 arg
  for arg in "$@"; do
    case "$arg" in
      -y|--yes) yes=1 ;;
      -h|--help)
        cat <<EOF
$(bold "pager uninstall") $(dim "— tear down system integration (keeps repo + .env)")

  Removes the LaunchAgent / systemd units, the ~/.local/bin/pager symlink,
  and the pager .env auto-source lines from your shell rc files.

  Does NOT delete $__PAGER_ROOT or your .env. If you want a full wipe,
  finish with: $(bold "rm -rf $__PAGER_ROOT")

  -y, --yes    skip the confirmation prompt
  -h, --help   this message
EOF
        return 0
        ;;
      *) echo "$(red "Unknown option:") $arg  (use --help for usage)" >&2; return 1 ;;
    esac
  done

  printf '%s\n\n' "$(bold "pager uninstall") $(dim "— $__PAGER_ROOT  (os: $PAGER_OS)")"
  echo "This will:"
  if [ "$PAGER_OS" = "mac" ]; then
    echo "  • launchctl bootout + remove ~/Library/LaunchAgents/com.pager.{agent,session,watch}.plist"
  else
    echo "  • systemctl --user stop + disable pager.service + pager-watch.timer"
    echo "    + remove ~/.config/systemd/user/pager*"
  fi
  echo "  • Remove ~/.local/bin/pager symlink"
  echo "  • Strip pager .env auto-source lines from ~/.bashrc, ~/.zshrc, ~/.zprofile, ~/.profile"
  echo "  • Leave $__PAGER_ROOT and your .env in place"
  echo

  if [ "$yes" != 1 ]; then
    printf "Proceed? [y/N] "
    local ans
    read -r ans
    case "$ans" in
      y|Y|yes|YES) ;;
      *) echo "Aborted."; return 1 ;;
    esac
  fi

  echo

  # 1. Service / agent teardown
  if [ "$PAGER_OS" = "mac" ]; then
    local uid label
    uid="$(id -u)"
    for label in com.pager.agent com.pager.session com.pager.watch; do
      if launchctl bootout "gui/$uid/$label" 2>/dev/null; then
        printf '  %s booted out %s\n' "$(green ✓)" "$label"
      fi
      if [ -f "$HOME/Library/LaunchAgents/$label.plist" ]; then
        rm -f "$HOME/Library/LaunchAgents/$label.plist"
        printf '  %s removed ~/Library/LaunchAgents/%s.plist\n' "$(green ✓)" "$label"
      fi
    done
    # Remove the ~/Applications/pager.app entry that bootstrap installs
    # (was a symlink in v0.5.3-0.5.4, a real copy from v0.5.5 onward).
    # rm -rf handles both cases.
    if [ -L "$HOME/Applications/pager.app" ] || [ -d "$HOME/Applications/pager.app" ]; then
      rm -rf "$HOME/Applications/pager.app"
      printf '  %s removed ~/Applications/pager.app\n' "$(green ✓)"
    fi
  else
    local unit
    for unit in pager-watch.timer pager-watch.service pager.service; do
      if systemctl --user is-enabled "$unit" >/dev/null 2>&1 || \
         systemctl --user is-active  "$unit" >/dev/null 2>&1; then
        systemctl --user stop    "$unit" 2>/dev/null || true
        systemctl --user disable "$unit" 2>/dev/null || true
        printf '  %s stopped + disabled %s\n' "$(green ✓)" "$unit"
      fi
      if [ -f "$HOME/.config/systemd/user/$unit" ]; then
        rm -f "$HOME/.config/systemd/user/$unit"
        printf '  %s removed ~/.config/systemd/user/%s\n' "$(green ✓)" "$unit"
      fi
    done
    systemctl --user daemon-reload 2>/dev/null || true
    # Note: we intentionally do NOT disable linger — the user may have other
    # --user services that depend on it.
  fi

  # 2. ~/.local/bin/pager symlink
  if [ -L "$HOME/.local/bin/pager" ] || [ -f "$HOME/.local/bin/pager" ]; then
    rm -f "$HOME/.local/bin/pager"
    printf '  %s removed ~/.local/bin/pager\n' "$(green ✓)"
  fi

  # 3. Strip the pager .env auto-source block from each shell rc file.
  #    Backs up first ($rc.pager.bak.<timestamp>) so the user can recover.
  local rc backup
  for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.zprofile" "$HOME/.profile"; do
    [ -f "$rc" ] || continue
    grep -qE 'pager/\.env' "$rc" 2>/dev/null || continue
    backup="$rc.pager.bak.$(date +%Y%m%d%H%M%S)"
    cp "$rc" "$backup"
    python3 - "$rc" <<'PYEOF'
import re, sys
p = sys.argv[1]
with open(p) as f: txt = f.read()
# Remove the 3-line block we (and earlier versions of bootstrap) write:
#   <blank>
#   # pager: auto-load secrets ...
#   [ -f "<some-path>/pager/.env" ] && set -a && . "<same path>" && set +a
txt2 = re.sub(
    r'\n?\n# pager:[^\n]*\n\[ -f "[^"]*pager/\.env"[^\n]*\n',
    '',
    txt,
)
# Also catch a stray line (no preceding comment) if a previous bootstrap version
# wrote just the [ -f ... ] line.
txt2 = re.sub(
    r'\n\[ -f "[^"]*pager/\.env"[^\n]*set \+a\n',
    '\n',
    txt2,
)
with open(p, 'w') as f: f.write(txt2)
PYEOF
    printf '  %s cleaned pager .env line from %s  %s\n' \
      "$(green ✓)" "$(basename "$rc")" "$(dim "(backup: $(basename "$backup"))")"
  done

  echo
  printf '%s\n' "$(green '✓ uninstall complete')"
  echo
  echo "Repo + your .env are still at: $__PAGER_ROOT"
  echo "To finish a full wipe:"
  printf '  %s  %s\n' "rm -rf $__PAGER_ROOT" "$(dim '# removes repo, logs, and your .env (irreversible)')"
  if [ "$PAGER_OS" = "mac" ]; then
    echo
    echo "Optional macOS extras:"
    printf '  %s  %s\n' "sfltool resetbtm" "$(dim '# clears stale Login Items entries + notifications')"
    printf '  %s\n' "$(dim '  (You can also remove tmux from System Settings → Privacy & Security → App Management.)')"
  fi
}

# ─── kill: drop a session WITHOUT pausing the watchdog ─────────────────────
# Same shape as the old (v0.2.0) `pager stop`. Use this when you want the
# watchdog to immediately respawn the session — e.g. to force a fresh claude
# process. Contrast with `pager stop`, which sets the semaphore so the
# watchdog stays paused after the kill.
cmd_kill() {
  require tmux
  if [ "${1-}" = "--all" ]; then
    tmux ls 2>/dev/null | awk -F: '{print $1}' | while read -r s; do
      tmux kill-session -t "$s" && echo "Killed: $s"
    done
    echo "(Watchdog still active — sessions will be respawned at next tick. Use 'pager stop' to keep them down.)"
    return 0
  fi
  local session="${1:-claude}"
  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session"
    echo "Killed session '$session'. (Watchdog will respawn at next tick.)"
  else
    echo "No session '$session' running."
  fi
}

# ─── restart: kill + start immediately ─────────────────────────────────────
# Doesn't wait for the watchdog. With --all, also bounces the watchdog
# process itself (helpful when the watchdog LaunchAgent / timer is in a
# weird state). Clears the stop semaphore.
cmd_restart() {
  require tmux
  if [ "${1-}" = "--all" ]; then
    tmux ls 2>/dev/null | awk -F: '{print $1}' | while read -r s; do
      tmux kill-session -t "$s" >/dev/null 2>&1 || true
      echo "Killed: $s"
    done
    _watchdog_disable >/dev/null 2>&1 || true
    sleep 1
    rm -f "$(_pager_stop_file)" 2>/dev/null || true
    cmd_start claude
    if _watchdog_enable >/dev/null 2>&1; then
      echo "Watchdog reloaded."
    fi
    echo "Restarted (all sessions + watchdog)."
    return 0
  fi
  local session="${1:-claude}"
  if tmux has-session -t "$session" 2>/dev/null; then
    tmux kill-session -t "$session"
    echo "Killed: $session"
  fi
  rm -f "$(_pager_stop_file)" 2>/dev/null || true
  cmd_start "$session"
}

# ─── status: list running sessions ─────────────────────────────────────────
cmd_status() {
  if ! command -v tmux >/dev/null; then
    echo "tmux not installed."
    return
  fi
  local sessions
  sessions="$(tmux ls -F '#{session_name}' 2>/dev/null || true)"
  if [ -z "$sessions" ]; then
    echo "No tmux sessions running."
    return
  fi

  # Format: NAME | CLAUDE | AGE | URL
  printf '%-16s %-7s %-10s %s\n' "NAME" "CLAUDE" "AGE" "REMOTE CONTROL URL"
  printf '%-16s %-7s %-10s %s\n' "----" "------" "---" "------------------"
  local s pane_pid claude_pid age_disp claude_disp url
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    pane_pid="$(tmux list-panes -t "$s":0 -F '#{pane_pid}' 2>/dev/null | head -1 || true)"
    claude_pid=""
    [ -n "$pane_pid" ] && claude_pid="$(pgrep -P "$pane_pid" 2>/dev/null | head -1 || true)"
    if [ -n "$claude_pid" ]; then
      claude_disp="alive"
      age_disp="$(ps -o etime= -p "$claude_pid" 2>/dev/null | tr -d ' ' || echo '-')"
    else
      claude_disp="DEAD"
      age_disp="-"
    fi
    url="$(tmux capture-pane -t "$s":0 -p -S - 2>/dev/null \
           | grep -oE 'https://claude\.ai/code/session_[A-Za-z0-9]+' \
           | tail -1 || true)"
    [ -n "$url" ] || url="(no remote-control URL)"
    printf '%-16s %-7s %-10s %s\n' "$s" "$claude_disp" "$age_disp" "$url"
  done <<< "$sessions"

  echo
  echo "Attach: pager attach <name>   ·   URL only: pager url [<name>|--all]"
}

# ─── url: print claude.ai Remote Control URL for a session ─────────────────
cmd_url() {
  require tmux
  url_for() {
    local s="$1"
    tmux has-session -t "$s" 2>/dev/null || { printf '%-20s %s\n' "[$s]" "no session"; return; }
    local url
    url=$(tmux capture-pane -t "$s":0 -p -S - 2>/dev/null \
          | grep -oE 'https://claude\.ai/code/session_[A-Za-z0-9]+' \
          | head -1 || true)
    if [ -n "$url" ]; then
      printf '%-20s %s\n' "[$s]" "$url"
    else
      printf '%-20s %s\n' "[$s]" "(no Remote Control URL — started without --remote-control?)"
    fi
  }
  if [ "${1-}" = "--all" ]; then
    tmux ls 2>/dev/null | awk -F: '{print $1}' | while read -r s; do url_for "$s"; done
  else
    url_for "${1:-claude}"
  fi
}

# ─── watchdog: one-tick health check + auto-restart of a session ───────────
# Designed to be called by a systemd user timer every ~60s. Idempotent: if the
# session is healthy it just appends a 'noop' row to logs/watch.csv and exits.
#
# Health signals:
#   tmux_alive       — tmux has the named session
#   claude_pid       — a claude process matching the session is running
#   rc_banner_seen   — recent pane output contains 'Remote Control active' or
#                      a 'https://claude.ai/code/session_…' URL
#
# Action policy (intentionally conservative for v1):
#   - Claude process dead → kill stale tmux session if any, then cmd_start.
#   - Claude process alive but rc_banner missing → log only. We don't yet
#     know whether banner-missing always means a dead Remote Control link
#     (it could just have scrolled off the captured window). Once watch.csv
#     captures real expiry events, refine the policy.
cmd_watchdog() {
  local session="${1:-claude}"

  local csv="$__PAGER_ROOT/logs/watch.csv"
  mkdir -p "$(dirname "$csv")"
  if [ ! -s "$csv" ]; then
    echo "timestamp,session,tmux_alive,claude_pid,rc_banner_seen,age_sec,action" > "$csv"
  fi

  local ts
  ts="$(date -Iseconds)"

  # ── early-bypass 1: stop semaphore ──
  # If the user ran `pager stop`, the semaphore is set. Log a noop row and
  # exit BEFORE making any tmux calls — this prevents the macOS TCC prompt
  # from firing every 70s while pager is intentionally stopped.
  if [ -f "$(_pager_stop_file)" ]; then
    printf '%s,%s,%s,%s,%s,%s,%s\n' \
      "$ts" "$session" "false" "" "false" "" "manually-stopped" >> "$csv"
    return 0
  fi

  # ── early-bypass 2: healthy claude (pgrep) ──
  # If pgrep finds a running `claude --remote-control <session>` process,
  # the session is healthy. Log noop and exit WITHOUT touching tmux.
  #
  # Motivation: every tmux call from this watchdog (which runs under one
  # launchd context) into the tmux server (spawned under another launchd
  # context) trips macOS's App Management TCC check — "tmux would like
  # to access data from other apps." Skipping tmux on healthy ticks means
  # the TCC prompt only fires AT MOST once per restart, not every 70 s.
  #
  # We also skip this fast path if PAGER_NO_REMOTE is set (sessions then
  # have no --remote-control arg, the pattern wouldn't match, and the
  # tmux-based diagnostic path is still right anyway).
  local pgrep_pid=""
  if [ -z "${PAGER_NO_REMOTE:-}" ]; then
    pgrep_pid="$(pgrep -f "claude .*--remote-control[[:space:]]+$session" 2>/dev/null | head -1 || true)"
  fi
  if [ -n "$pgrep_pid" ]; then
    local age_sec_fast=""
    age_sec_fast="$(age_seconds_for_pid "$pgrep_pid")"
    printf '%s,%s,%s,%s,%s,%s,%s\n' \
      "$ts" "$session" "true" "$pgrep_pid" "true" "${age_sec_fast:-}" "noop" >> "$csv"
    return 0
  fi

  # ── slow path: pgrep found nothing, run the full tmux-based diagnostic ──
  # We get here when claude isn't running (needs a restart), or when running
  # in PAGER_NO_REMOTE mode where pgrep's pattern can't match.
  require tmux

  local tmux_alive=false pane_pid="" claude_pid="" rc_banner=false age_sec="" action="noop"

  if tmux has-session -t "$session" 2>/dev/null; then
    tmux_alive=true
    pane_pid="$(tmux list-panes -t "$session":0 -F '#{pane_pid}' 2>/dev/null | head -1 || true)"
  fi

  # The wrapper bash that tmux spawned holds the original `claude …` argv
  # forever, so `pgrep -f claude` finds it even after claude exits. The
  # reliable signal is: does pane_pid have a running direct child? The
  # wrapper's `;`-chain runs `claude` as a child; once claude exits, the
  # chain runs `echo; exec bash` and the wrapper has no children until the
  # user spawns one. So "no child of pane_pid" == "claude is dead".
  if [ -n "$pane_pid" ]; then
    claude_pid="$(pgrep -P "$pane_pid" 2>/dev/null | head -1 || true)"
  fi

  if [ -n "$claude_pid" ]; then
    age_sec="$(age_seconds_for_pid "$claude_pid")"
  fi

  if [ "$tmux_alive" = true ]; then
    if tmux capture-pane -t "$session":0 -p -S -200 2>/dev/null \
       | grep -qE 'Remote Control active|https://claude\.ai/code/session_'; then
      rc_banner=true
    fi
  fi

  if [ -z "$claude_pid" ]; then
    # Before attempting restart, verify claude is actually installed. Without
    # this guard, the watchdog will fire every 70s, fail at cmd_start every
    # time, fill watch.csv with restart-failed rows, and on macOS each attempt
    # can trip TCC prompts. Log a single clear "claude-missing" instead and
    # exit cleanly. Once the user installs claude, the next tick will see it
    # and restart normally.
    if ! command -v claude >/dev/null 2>&1; then
      action="claude-missing"
    else
      action="restart"
      if [ "$tmux_alive" = true ]; then
        tmux kill-session -t "$session" 2>/dev/null || true
      fi
      # Re-launch via cmd_start; it handles tmux + logging + remote-control flag.
      cmd_start "$session" >/dev/null 2>&1 || action="restart-failed"
    fi
  fi

  printf '%s,%s,%s,%s,%s,%s,%s\n' \
    "$ts" "$session" "$tmux_alive" "${claude_pid:-}" "$rc_banner" "${age_sec:-}" "$action" \
    >> "$csv"
}

# ─── ssh: SSH to inventory host with creds from .env ───────────────────────
cmd_ssh() {
  local alias="${1:?Usage: pager ssh <host-alias> [command]}"
  shift || true

  local inv="${PAGER_INVENTORY:-$__PAGER_ROOT/inventory.yaml}"
  [ -f "$inv" ] || err "Inventory not found: $inv"

  require python3

  eval "$(python3 - "$alias" "$inv" <<'PY'
import sys, yaml, shlex
alias, inv = sys.argv[1], sys.argv[2]
with open(inv) as f:
    data = yaml.safe_load(f) or {}
hosts = data.get('hosts') or {}
h = hosts.get(alias)
if not h:
    print(f"echo 'Unknown host: {alias}' >&2; exit 2")
    sys.exit(0)
for k in ('host', 'user', 'port', 'key', 'password_env'):
    v = h.get(k, '') or ''
    print(f"H_{k.upper()}={shlex.quote(str(v))}")
PY
)"

  H_PORT="${H_PORT:-22}"
  H_USER="${H_USER:-$(whoami)}"
  [ -n "$H_HOST" ] || err "Host '$alias' has no 'host' field"

  local opts=(-o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -p "$H_PORT")

  if [ -n "$H_KEY" ]; then
    opts+=(-i "${H_KEY/#\~/$HOME}" -o IdentitiesOnly=yes)
    exec ssh "${opts[@]}" "$H_USER@$H_HOST" "$@"
  fi

  if [ -n "$H_PASSWORD_ENV" ]; then
    local pass="${!H_PASSWORD_ENV:-}"
    [ -n "$pass" ] || err "Env var \$$H_PASSWORD_ENV is empty. Set it in .env."
    require sshpass
    SSHPASS="$pass" exec sshpass -e ssh "${opts[@]}" "$H_USER@$H_HOST" "$@"
  fi

  exec ssh "${opts[@]}" "$H_USER@$H_HOST" "$@"
}

# ─── run: run an action script on a remote host ────────────────────────────
cmd_run() {
  local alias="${1:?Usage: pager run <host-alias> <action> [-- args...]}"
  local action="${2:?Usage: pager run <host-alias> <action> [-- args...]}"
  shift 2
  [ "${1-}" = "--" ] && shift || true

  local actions_dir="${PAGER_ACTIONS_DIR:-$__PAGER_ROOT/actions}"
  local script="$actions_dir/$action.sh"

  if [ ! -f "$script" ]; then
    echo "Action '$action' not found at $script" >&2
    echo "Available:" >&2
    for f in "$actions_dir"/*.sh; do
      [ -e "$f" ] || continue
      printf '  %s\n' "$(basename "$f" .sh)" >&2
    done
    return 2
  fi

  exec "$__PAGER_ROOT/bin/pager" ssh "$alias" bash -s -- "$@" < "$script"
}

# ─── doctor: self-diagnostic ───────────────────────────────────────────────
# Runs a battery of checks and reports each as pass / warn / fail with a
# one-line hint when something is wrong. Designed to be the first thing a
# user runs when "it isn't working". Exit code: 0 if all pass, 1 if any fail.
cmd_doctor() {
  local fails=0 warns=0

  pass() { printf '  %s %s\n' "$(green ✓)" "$1"; }
  warn() { printf '  %s %s\n'   "$(yellow !)" "$1"; [ -n "${2-}" ] && printf '      %s %s\n' "$(dim '↳')" "$2"; warns=$((warns+1)); }
  fail() { printf '  %s %s\n'   "$(red ✗)" "$1";    [ -n "${2-}" ] && printf '      %s %s\n' "$(dim '↳')" "$2"; fails=$((fails+1)); }

  printf '%s\n\n' "$(bold "pager doctor") $(dim "— $__PAGER_ROOT")"

  # ── 1. core deps ────────────────────────────────────────────────────────
  printf '%s\n' "$(bold 'Dependencies')"
  if command -v tmux >/dev/null;     then pass "tmux $(tmux -V | awk '{print $2}')"; else fail "tmux not installed" "apt install tmux"; fi
  if command -v claude >/dev/null;   then pass "claude $(claude --version 2>/dev/null | awk '{print $1}' | head -1)";
     else warn "claude not on PATH" "Install Claude Code CLI: https://claude.com/code"; fi
  if command -v python3 >/dev/null;  then pass "python3 $(python3 -V 2>&1 | awk '{print $2}')"; else warn "python3 missing" "needed for 'pager ssh' inventory parsing"; fi

  # ── 2. PATH resolution / collision ──────────────────────────────────────
  printf '\n%s\n' "$(bold 'Install & PATH')"
  local pager_in_path real_pager
  pager_in_path="$(command -v pager 2>/dev/null || true)"
  if [ -z "$pager_in_path" ]; then
    fail "'pager' is not on PATH" "Re-run bootstrap.sh, or symlink: ln -s $__PAGER_ROOT/bin/pager ~/.local/bin/pager"
  else
    real_pager="$(readlink -f "$pager_in_path" 2>/dev/null || echo "$pager_in_path")"
    if [ "$real_pager" = "$__PAGER_ROOT/bin/pager" ]; then
      pass "'pager' resolves to $pager_in_path → this repo"
    elif [ "$pager_in_path" = "/usr/bin/pager" ] || [ "$pager_in_path" = "/usr/sbin/pager" ]; then
      fail "'pager' resolves to $pager_in_path (Debian BSD-pager / less alias)" \
           "Add ~/.local/bin to PATH before /usr/bin, or run bootstrap.sh"
    else
      warn "'pager' resolves to $pager_in_path (not this repo)" \
           "Expected $__PAGER_ROOT/bin/pager — multiple installs?"
    fi
  fi

  # ── 3. .env perms ───────────────────────────────────────────────────────
  printf '\n%s\n' "$(bold 'Secrets')"
  if [ -f "$__PAGER_ROOT/.env" ]; then
    local mode
    mode="$(file_mode "$__PAGER_ROOT/.env" || true)"
    mode="${mode:-?}"
    if [ "$mode" = "600" ]; then
      pass ".env perms 600"
    else
      fail ".env perms are $mode (want 600)" "chmod 600 $__PAGER_ROOT/.env"
    fi
  else
    warn ".env missing" "cp $__PAGER_ROOT/.env.example $__PAGER_ROOT/.env && chmod 600 $__PAGER_ROOT/.env"
  fi

  # ── 4. claude.json trust flag ───────────────────────────────────────────
  printf '\n%s\n' "$(bold 'Claude Code workspace trust')"
  if [ -f "$HOME/.claude.json" ] && command -v python3 >/dev/null; then
    local trust
    trust="$(python3 - <<'PY' 2>/dev/null
import json, os
try:
    with open(os.path.expanduser('~/.claude.json')) as f: d = json.load(f)
    print('true' if d.get('projects', {}).get(os.path.expanduser('~'), {}).get('hasTrustDialogAccepted') else 'false')
except Exception:
    print('error')
PY
)"
    case "$trust" in
      true)  pass "\$HOME pre-trusted in ~/.claude.json (autostart safe)" ;;
      false) fail "\$HOME not trusted in ~/.claude.json" "Re-run bootstrap.sh — step 5 fixes this" ;;
      *)     warn "couldn't read ~/.claude.json" "manual check: jq '.projects.\"'\$HOME'\"' ~/.claude.json" ;;
    esac
  else
    # shellcheck disable=SC2088  # ~/.claude.json shown literally to user
    warn "~/.claude.json not found" "First-run claude will create it; bootstrap.sh pre-trusts \$HOME"
  fi

  # ── 5. services (systemd on Linux, launchd on macOS) ────────────────────
  printf '\n%s\n' "$(bold 'Services')"
  if [ "$PAGER_OS" = "mac" ]; then
    local uid
    uid="$(id -u)"
    # Warn if either of the legacy two-agent plists is still on disk — the
    # user should re-run bootstrap to migrate to the single com.pager.agent.
    for old in com.pager.session com.pager.watch; do
      if [ -f "$HOME/Library/LaunchAgents/$old.plist" ]; then
        warn "legacy LaunchAgent $old still installed" "re-run macos/bootstrap.sh to migrate to com.pager.agent"
      fi
    done
    if [ -f "$HOME/Library/LaunchAgents/com.pager.agent.plist" ]; then
      if launchctl print "gui/$uid/com.pager.agent" >/dev/null 2>&1; then
        pass "com.pager.agent: loaded"
      else
        fail "com.pager.agent: not loaded" "launchctl bootstrap gui/\$(id -u) ~/Library/LaunchAgents/com.pager.agent.plist"
      fi
    else
      warn "com.pager.agent not installed" "re-run macos/bootstrap.sh"
    fi
    # LaunchAgents only run at login — no boot-time equivalent of linger.
    # We report this as informational rather than warn, because "fix it" is
    # "enable macOS auto-login" which is a personal choice, not a bug.
    pass "autostart: at login (LaunchAgent — no boot-time equivalent on macOS)"
  else
    local svc_state timer_state
    if systemctl --user list-unit-files pager.service 2>/dev/null | grep -q '^pager.service'; then
      svc_state="$(systemctl --user is-active pager.service 2>/dev/null || true)"
      case "$svc_state" in
        active) pass "pager.service: active" ;;
        *)      fail "pager.service: $svc_state" "systemctl --user start pager.service" ;;
      esac
    else
      warn "pager.service not installed" "make service  (or re-run bootstrap.sh)"
    fi
    if systemctl --user list-unit-files pager-watch.timer 2>/dev/null | grep -q '^pager-watch.timer'; then
      timer_state="$(systemctl --user is-active pager-watch.timer 2>/dev/null || true)"
      case "$timer_state" in
        active) pass "pager-watch.timer: active" ;;
        *)      warn "pager-watch.timer: $timer_state" "systemctl --user enable --now pager-watch.timer" ;;
      esac
    else
      warn "pager-watch.timer not installed" "make watchdog  (or re-run bootstrap.sh)"
    fi
    if [ "$(loginctl show-user "$USER" -p Linger 2>/dev/null | cut -d= -f2)" = "yes" ]; then
      pass "linger enabled (services start at boot)"
    else
      warn "linger not enabled — services won't start until first login" "sudo loginctl enable-linger \$USER"
    fi
  fi

  # ── 6. watchdog freshness ───────────────────────────────────────────────
  printf '\n%s\n' "$(bold 'Watchdog state')"
  local csv="$__PAGER_ROOT/logs/watch.csv"
  if [ -s "$csv" ]; then
    local last_ts now_epoch last_epoch age
    last_ts="$(tail -1 "$csv" | cut -d, -f1)"
    last_epoch="$(date_to_epoch "$last_ts")"
    now_epoch="$(date +%s)"
    age=$(( now_epoch - last_epoch ))
    if [ "$age" -lt 120 ]; then
      pass "last watchdog tick ${age}s ago"
    elif [ "$age" -lt 600 ]; then
      warn "last watchdog tick ${age}s ago (timer interval is 60s — running late)"
    else
      if [ "$PAGER_OS" = "mac" ]; then
        fail "last watchdog tick ${age}s ago (timer stalled?)" "launchctl print gui/\$(id -u)/com.pager.agent"
      else
        fail "last watchdog tick ${age}s ago (timer stalled?)" "systemctl --user status pager-watch.timer"
      fi
    fi
    local non_noop
    non_noop="$(awk -F, 'NR>1 && $7 != "noop" { n++ } END { print n+0 }' "$csv")"
    if [ "$non_noop" -gt 0 ]; then
      warn "$non_noop non-noop event(s) in watch.csv" "grep -v ',noop\$' $csv"
    fi
  else
    warn "no watchdog history yet" "Timer takes ~2 min to fire after install"
  fi

  # ── 7. sessions ─────────────────────────────────────────────────────────
  printf '\n%s\n' "$(bold 'Sessions')"
  if command -v tmux >/dev/null && tmux ls 2>/dev/null | grep -q .; then
    tmux ls 2>/dev/null | sed 's/^/  /'
  else
    warn "no tmux sessions running" "pager start"
  fi

  # ── verdict ─────────────────────────────────────────────────────────────
  echo
  if [ "$fails" -eq 0 ] && [ "$warns" -eq 0 ]; then
    printf '%s\n' "$(green '✓ all checks passed')"
    return 0
  elif [ "$fails" -eq 0 ]; then
    printf '%s warnings: %d (non-fatal)\n' "$(yellow '!')" "$warns"
    return 0
  else
    printf '%s failures: %d   warnings: %d\n' "$(red '✗')" "$fails" "$warns"
    return 1
  fi
}

# Per-OS lines for the cmd_help Service block. Kept here (not in cmd_help)
# so the heredoc stays a clean one-pass cat.
__pager_help_service_block() {
  if [ "$PAGER_OS" = "mac" ]; then
    cat <<EOF
  launchctl print gui/\$(id -u)/com.pager.agent    $(dim "# combined session+watchdog agent")
  tail -F $__PAGER_ROOT/logs/launchd-agent.{out,err} $(dim "# launchd-level logs")
  launchctl kickstart gui/\$(id -u)/com.pager.agent $(dim "# fire a watchdog tick now")
EOF
  else
    cat <<EOF
  systemctl --user status pager.service       $(dim "# autostart unit")
  journalctl --user -u pager.service          $(dim "# service logs")
  systemctl --user status pager-watch.timer   $(dim "# watchdog timer")
EOF
  fi
}

# ─── help: print the usage menu ────────────────────────────────────────────
cmd_help() {
  cat <<EOF
$(bold "pager") $(dim "— persistent remote-session toolkit for Claude Code")

$(bold "Usage:")  pager $(dim "<command>") $(dim "[args]")

$(bold "Session commands")
  $(bold "start")   $(dim "[name]")            start a tmux session (default 'claude') running
                              claude --remote-control + bypass perms. Clears the
                              stop semaphore so the watchdog resumes.
  $(bold "attach")  $(dim "[name]")            attach terminal to <name> ($(dim "detach: Ctrl-b d"))
  $(bold "stop")    $(dim "[name|--all]")      kill a session and PAUSE the watchdog (writes
                              logs/.stopped). --all also unloads the watchdog
                              process itself. 'pager start' to resume.
  $(bold "kill")    $(dim "[name|--all]")      kill a session WITHOUT pausing the watchdog —
                              watchdog will respawn it at the next tick.
                              Use this to force a fresh claude process.
  $(bold "restart") $(dim "[name|--all]")      kill + start immediately. --all also bounces
                              the watchdog process. Clears the stop semaphore.
  $(bold "status")                     list running tmux sessions
  $(bold "url")    $(dim "[name|--all]")       print phone-accessible claude.ai URL(s)
  $(bold "watchdog") $(dim "[name]")           one-tick health check; restart session if dead.
                              Run every minute via the pager-watch user timer.
                              Appends a row to logs/watch.csv each tick.
  $(bold "doctor")                     self-diagnostic: PATH, trust flag, services,
                              watchdog freshness, .env perms. Exits non-zero if any
                              check fails. First thing to run when things look off.

$(bold "Remote ops")
  $(bold "ssh")    $(dim "<alias> [cmd]")      SSH to a host from inventory.yaml using creds from .env
  $(bold "run")    $(dim "<alias> <action>")   run actions/<action>.sh on a remote host

$(bold "Trust")
  $(bold "trust")    $(dim "[--check|--reset] [PATH]")  pre-accept Claude Code's "Trust this folder?"
                              dialog for PATH (default \$HOME). Bootstrap
                              already trusts \$HOME; use this to add other
                              paths, verify state (--check), or reset.

$(bold "Autostart") $(dim "(opt-in; default install does NOT register it)")
  $(bold "autostart")                  show whether autostart is enabled
  $(bold "autostart enable")           install LaunchAgent (Mac) / systemd unit (Linux)
                              for "comes back at login". Triggers macOS TCC
                              prompts the first time.
  $(bold "autostart disable")          remove the autostart unit. Sessions you
                              started manually keep running.

$(bold "Other")
  $(bold "uninstall") $(dim "[-y]")            tear down system integration (services, symlink,
                              shell rc lines). Keeps the repo + .env intact.
                              Final cleanup: rm -rf $__PAGER_ROOT
  $(bold "help")                       this message

$(bold "Env overrides")
  PAGER_NO_REMOTE=1 pager start sandbox   $(dim "# skip --remote-control (local only)")
  PAGER_INVENTORY, PAGER_ACTIONS_DIR      $(dim "# point at non-default locations")

$(bold "Files")
  Inventory:  $__PAGER_ROOT/inventory.yaml
  Actions:    $__PAGER_ROOT/actions/
  Logs:       $__PAGER_ROOT/logs/
  Secrets:    $__PAGER_ROOT/.env  $(dim "(chmod 600, gitignored)")

$(bold "Service") $(dim "($PAGER_OS)")
$(__pager_help_service_block)
  $__PAGER_ROOT/logs/watch.csv                $(dim "# watchdog state log")

$(bold "Docs:")  $__PAGER_ROOT/README.md, $__PAGER_ROOT/CLAUDE.md
$(bold "Repo:")  github.com/jawwadzafar/pager $(dim "(MIT)")
EOF
}

# ─── dispatch ──────────────────────────────────────────────────────────────
case "${1-}" in
  start|bg)            shift; cmd_start "$@" ;;
  attach)              shift; cmd_attach "$@" ;;
  stop)                shift; cmd_stop "$@" ;;
  kill)                shift; cmd_kill "$@" ;;
  restart)             shift; cmd_restart "$@" ;;
  autostart)           shift; cmd_autostart "$@" ;;
  trust)               shift; cmd_trust "$@" ;;
  uninstall)           shift; cmd_uninstall "$@" ;;
  status|ls)           shift; cmd_status "$@" ;;
  url)                 shift; cmd_url "$@" ;;
  watchdog)            shift; cmd_watchdog "$@" ;;
  doctor|check)        shift; cmd_doctor "$@" ;;
  ssh)                 shift; cmd_ssh "$@" ;;
  run)                 shift; cmd_run "$@" ;;
  help|--help|-h|"")   cmd_help ;;
  *)                   echo "$(red "Unknown subcommand:") $1" >&2; cmd_help >&2; exit 1 ;;
esac
