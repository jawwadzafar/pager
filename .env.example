# pager — environment template
# Copy this file to .env (`cp .env.example .env`), chmod 600, fill in real values.
# The .env file is gitignored — never commit it.

# ─── Sudo (optional) ─────────────────────────────────────────────────────────
# If set, pager scripts that need root use `sudo -A` via lib/sudo.sh and never
# prompt. Leave unset to fall back to interactive sudo (which still works).
# SUDO_PASSWORD=""

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Personal Access Token (classic or fine-grained). Scopes needed:
#   • repo        — clone/push private repos
#   • read:org    — list org repos (optional)
# Used by gh-CLI, git over HTTPS, and any script that hits the GitHub API.
GH_TOKEN=""
GITHUB_TOKEN="$GH_TOKEN"

# ─── SSH credentials (only needed for password-auth hosts) ───────────────────
# Reference these from inventory.yaml via `password_env: VAR_NAME`. Prefer
# key auth (key:) over passwords whenever the remote allows it.
# HOMESERVER_SSH_PASS=""
# LEGACY_SSH_PASS=""

# ─── Cloud / API tokens (add as you need them) ───────────────────────────────
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# ─── Ops helpers (rarely need to change) ─────────────────────────────────────
# Where inventory and actions live; default to this repo.
PAGER_INVENTORY="${PAGER_INVENTORY:-$HOME/pager/inventory.yaml}"
PAGER_ACTIONS_DIR="${PAGER_ACTIONS_DIR:-$HOME/pager/actions}"
